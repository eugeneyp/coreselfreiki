---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import '@fontsource/geist-sans';
import '@fontsource/geist-mono';

interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "Core Self Reiki - Healing Through Energy & Mindfulness", 
  description = "Discover inner peace and healing through Core Self Reiki. Experience transformative energy healing sessions online or in-person with certified practitioners." 
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    
    <link rel="icon" type="image/png" media="(prefers-color-scheme: light)" href="/coreselfreiki/icon-light-32x32.png" />
    <link rel="icon" type="image/png" media="(prefers-color-scheme: dark)" href="/coreselfreiki/icon-dark-32x32.png" />
    <link rel="icon" type="image/svg+xml" href="/coreselfreiki/icon.svg" />
    <link rel="apple-touch-icon" href="/coreselfreiki/apple-icon.png" />
  </head>
  <body class="font-sans antialiased">
    <Header />
    <slot />
    <Footer />
  </body>
</html>